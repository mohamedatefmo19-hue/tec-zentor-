<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.5">
  <title>Zentor · تفاصيل الكورس</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: #f4f7fc;
      color: #0b1e33;
      display: flex;
      min-height: 100vh;
    }
    body.dark-mode { background: #0b0e14; color: #eef2f6; }

    /* ---------- Sidebar ---------- */
    .sidebar {
      width: 260px; background: #ffffff; border-left: 1px solid #e7edf5;
      padding: 2rem 1.2rem; display: flex; flex-direction: column; position: fixed;
      top: 0; right: 0; bottom: 0; z-index: 1000; transition: transform 0.3s ease; transform: translateX(0);
    }
    body.dark-mode .sidebar { background: #141a26; border-left-color: #2a3442; }
    .sidebar.closed { transform: translateX(100%); }
    .sidebar-logo { display: flex; align-items: center; gap: 0.7rem; margin-bottom: 2.5rem; }
    .sidebar-logo i { font-size: 1.8rem; color: #2a7de1; background: #e8f0fe; padding: 0.6rem; border-radius: 14px; }
    body.dark-mode .sidebar-logo i { background: #1f2a40; color: #6b9ef0; }
    .sidebar-logo span { font-weight: 700; font-size: 1.5rem; }
    .sidebar nav { flex: 1; }
    .sidebar nav a {
      display: flex; align-items: center; gap: 0.8rem; padding: 0.8rem 1rem; border-radius: 12px;
      color: #4a5b7a; text-decoration: none; font-weight: 500; transition: 0.15s; margin-bottom: 0.3rem;
    }
    .sidebar nav a i { width: 1.4rem; }
    .sidebar nav a:hover, .sidebar nav a.active { background: #eef4fe; color: #1a67c4; }
    body.dark-mode .sidebar nav a:hover, body.dark-mode .sidebar nav a.active { background: #1f2a40; color: #6b9ef0; }
    .sidebar-footer {
      border-top: 1px solid #e7edf5; padding-top: 1.2rem; margin-top: 0.5rem; font-size: 0.9rem;
      font-weight: 600; color: #6b7d9c; cursor: pointer; display: flex; align-items: center; gap: 0.6rem;
    }
    .sidebar-footer:hover { color: #e74c3c; }
    .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 999; }
    .sidebar-overlay.show { display: block; }

    /* ---------- Main ---------- */
    .main {
      flex: 1; margin-right: 260px; padding: 1.8rem 2rem 2.5rem; transition: margin-right 0.3s ease;
      overflow-x: hidden; width: 100%;
    }
    .main.expanded { margin-right: 0; }
    .navbar { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem; }
    .navbar h1 { font-size: 1.7rem; font-weight: 700; }
    .navbar-actions { display: flex; align-items: center; gap: 1.2rem; }
    .navbar-actions button { background: none; border: none; font-size: 1.2rem; color: #4a5b7a; cursor: pointer; }
    body.dark-mode .navbar-actions button { color: #b0c0d4; }
    .navbar-actions button:hover { color: #2a7de1; }
    .lang-dark { display: flex; gap: 0.6rem; }
    .lang-dark button { background: none; border: none; font-weight: 600; color: #2a7de1; cursor: pointer; font-size: 0.85rem; }
    .lang-dark .dark-toggle { color: #6b7d9c; }
    body.dark-mode .lang-dark .dark-toggle { color: #b0c0d4; }
    .hamburger { display: none; background: none; border: none; font-size: 1.5rem; color: #4a5b7a; cursor: pointer; }
    body.dark-mode .hamburger { color: #b0c0d4; }

    /* ---------- Course Header ---------- */
    .course-header {
      background: #ffffff; border-radius: 24px; padding: 1.8rem 2rem; margin-bottom: 2rem;
      border: 1px solid #eef2f8; display: flex; gap: 2rem; flex-wrap: wrap; align-items: center;
    }
    body.dark-mode .course-header { background: #1a1f2b; border-color: #2a3442; }
    .course-header .thumb {
      width: 160px; height: 120px; border-radius: 16px; background: #dfe6f0; object-fit: cover; flex-shrink: 0;
    }
    body.dark-mode .course-header .thumb { background: #2a3442; }
    .course-header .info { flex: 1; }
    .course-header .info h2 { font-size: 1.6rem; font-weight: 700; margin-bottom: 0.3rem; }
    .course-header .info .desc { color: #6b7d9c; margin-bottom: 0.8rem; }
    body.dark-mode .course-header .info .desc { color: #9aabbf; }
    .course-header .info .meta { display: flex; gap: 1.5rem; flex-wrap: wrap; font-size: 0.9rem; }
    .course-header .info .meta span { display: flex; align-items: center; gap: 0.4rem; }
    .course-header .info .meta i { color: #2a7de1; width: 1.2rem; }
    .badge-status {
      padding: 0.25rem 1rem; border-radius: 30px; font-size: 0.75rem; font-weight: 600;
      background: #e8f0fe; color: #1a67c4;
    }
    .badge-status.archived { background: #fef3e2; color: #b9770e; }

    /* ---------- Stats ---------- */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1.2rem; margin-bottom: 2rem; }
    .stat-card {
      background: #ffffff; border-radius: 20px; padding: 1.2rem; border: 1px solid #eef2f8; text-align: center;
    }
    body.dark-mode .stat-card { background: #1a1f2b; border-color: #2a3442; }
    .stat-card .label { font-size: 0.8rem; color: #6b7d9c; font-weight: 500; text-transform: uppercase; letter-spacing: 0.3px; }
    .stat-card .value { font-size: 2rem; font-weight: 700; margin: 0.3rem 0; }
    .stat-card i { color: #2a7de1; opacity: 0.6; font-size: 1.2rem; }

    /* ---------- Students List ---------- */
    .card-panel {
      background: #ffffff; border-radius: 20px; padding: 1.5rem; border: 1px solid #eef2f8; margin-bottom: 1.5rem;
    }
    body.dark-mode .card-panel { background: #1a1f2b; border-color: #2a3442; }
    .card-panel h3 { font-size: 1rem; font-weight: 600; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
    .card-panel h3 i { color: #2a7de1; }
    .student-item {
      display: flex; align-items: center; gap: 1rem; padding: 0.6rem 0; border-bottom: 1px solid #f0f4fa;
    }
    body.dark-mode .student-item { border-bottom-color: #2a3442; }
    .student-item .avatar {
      width: 36px; height: 36px; border-radius: 50%; background: #e8f0fe; display: flex;
      align-items: center; justify-content: center; color: #2a7de1; font-weight: 700;
    }
    .student-item .name { font-weight: 500; }
    .student-item .email { font-size: 0.85rem; color: #6b7d9c; margin-right: auto; }

    .empty-state { text-align: center; padding: 2rem; color: #8a9bb5; }
    .empty-state i { font-size: 2.5rem; margin-bottom: 0.5rem; opacity: 0.5; }

    .btn-primary {
      background: #2a7de1; color: white; border: none; padding: 0.6rem 1.4rem; border-radius: 40px;
      font-weight: 600; cursor: pointer; transition: 0.15s; display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none;
    }
    .btn-primary:hover { background: #1a67c4; }
    .btn-secondary {
      background: #eef2f8; color: #1a253a; border: none; padding: 0.6rem 1.4rem; border-radius: 40px;
      font-weight: 600; cursor: pointer; transition: 0.15s; display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none;
    }
    body.dark-mode .btn-secondary { background: #2a3442; color: #eef2f6; }
    .btn-secondary:hover { background: #dfe6f0; }
    .action-bar { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem; }

    .toast-container { position: fixed; top: 1rem; right: 1rem; z-index: 3000; display: flex; flex-direction: column; gap: 0.5rem; }
    .toast {
      padding: 0.8rem 1.5rem; border-radius: 14px; background: white; box-shadow: 0 8px 20px rgba(0,0,0,0.15);
      font-weight: 500; font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem; animation: slideIn 0.3s ease;
    }
    body.dark-mode .toast { background: #2a3442; color: #eef2f6; }
    .toast.success { border-right: 4px solid #10B981; }
    .toast.error { border-right: 4px solid #EF4444; }
    @keyframes slideIn { from { transform: translateX(-100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

    @media (max-width: 768px) {
      .hamburger { display: block; }
      .main { margin-right: 0; }
      .sidebar { transform: translateX(100%); }
      .sidebar.closed { transform: translateX(100%); }
      .sidebar.open { transform: translateX(0); }
      .course-header { flex-direction: column; align-items: flex-start; }
      .course-header .thumb { width: 100%; height: 160px; }
    }
    @media (max-width: 480px) { .stats-grid { grid-template-columns: 1fr 1fr; } .action-bar { flex-direction: column; } }
  </style>
</head>
<body>

  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo"><i class="fas fa-graduation-cap"></i><span>Zentor</span></div>
    <nav>
      <a href="dashboard.html"><i class="fas fa-chart-pie"></i> <span data-key="dashboard">لوحة التحكم</span></a>
      <a href="courses.html" class="active"><i class="fas fa-book-open"></i> <span data-key="courses">الكورسات</span></a>
      <a href="lessons.html"><i class="fas fa-file-alt"></i> <span data-key="lessons">الدروس</span></a>
      <a href="live-classes.html"><i class="fas fa-video"></i> <span data-key="live">البث المباشر</span></a>
      <a href="students.html"><i class="fas fa-users"></i> <span data-key="students">الطلاب</span></a>
      <a href="assignments.html"><i class="fas fa-clipboard-list"></i> <span data-key="assignments">الواجبات</span></a>
      <a href="exams.html"><i class="fas fa-file-alt"></i> <span data-key="exams">الامتحانات</span></a>
      <a href="revenue.html"><i class="fas fa-dollar-sign"></i> <span data-key="revenue">الإيرادات</span></a>
      <a href="messages.html"><i class="fas fa-comments"></i> <span data-key="messages">الرسائل</span></a>
      <a href="settings.html"><i class="fas fa-cog"></i> <span data-key="settings">الإعدادات</span></a>
    </nav>
    <div class="sidebar-footer" id="logoutBtn"><i class="fas fa-sign-out-alt"></i> <span data-key="logout">تسجيل الخروج</span></div>
  </aside>

  <div class="main" id="mainContent">
    <header class="navbar">
      <div style="display:flex; align-items:center; gap:1rem;">
        <button class="hamburger" id="hamburgerBtn"><i class="fas fa-bars"></i></button>
        <h1 id="pageTitle">📘 تفاصيل الكورس</h1>
      </div>
      <div class="navbar-actions">
        <div class="lang-dark">
          <button id="langToggle"><i class="fas fa-globe"></i> <span id="langLabel">AR</span></button>
          <button class="dark-toggle" id="darkToggle"><i class="fas fa-moon"></i></button>
        </div>
        <button><i class="fas fa-user-circle" style="font-size:1.6rem;"></i></button>
      </div>
    </header>

    <div id="courseHeader" class="course-header">
      <div class="empty-state" style="width:100%;"><i class="fas fa-spinner fa-spin"></i><br>جاري تحميل الكورس...</div>
    </div>

    <div class="action-bar">
      <a href="#" id="viewLessonsBtn" class="btn-primary"><i class="fas fa-file-alt"></i> عرض الدروس</a>
      <a href="#" id="uploadLessonBtn" class="btn-secondary"><i class="fas fa-upload"></i> رفع درس</a>
      <a href="courses.html" class="btn-secondary"><i class="fas fa-arrow-left"></i> العودة للكورسات</a>
    </div>

    <div class="stats-grid" id="statsGrid">
      <div class="stat-card"><div class="label">الطلاب</div><div class="value" id="statStudents">—</div><i class="fas fa-user-graduate"></i></div>
      <div class="stat-card"><div class="label">الدروس</div><div class="value" id="statLessons">—</div><i class="fas fa-file-alt"></i></div>
      <div class="stat-card"><div class="label">الإيرادات</div><div class="value" id="statRevenue">—</div><i class="fas fa-dollar-sign"></i></div>
      <div class="stat-card"><div class="label">الإكمال</div><div class="value" id="statCompletion">—</div><i class="fas fa-chart-line"></i></div>
    </div>

    <div class="card-panel">
      <h3><i class="fas fa-users"></i> الطلاب المسجلين</h3>
      <div id="studentsList"><div class="empty-state"><i class="fas fa-spinner fa-spin"></i><br>جاري تحميل الطلاب...</div></div>
    </div>
  </div>

  <div class="toast-container" id="toastContainer"></div>

  <script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/11.0.0/firebase-app.js";
    import { getAuth, onAuthStateChanged, signOut } from "https://www.gstatic.com/firebasejs/11.0.0/firebase-auth.js";
    import { getFirestore, doc, getDoc, collection, getDocs, query, where } from "https://www.gstatic.com/firebasejs/11.0.0/firebase-firestore.js";

    const firebaseConfig = {
      apiKey: "AIzaSyBOd-cHm8J84BMwdlP8a3zOVlK8sboUFj0",
      authDomain: "zentor-caaf1.firebaseapp.com",
      projectId: "zentor-caaf1",
      storageBucket: "zentor-caaf1.firebasestorage.app",
      messagingSenderId: "681267238383",
      appId: "1:681267238383:web:0c93fb405bfd6b5903921a",
      measurementId: "G-X80GNJHMS5"
    };

    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);
    const db = getFirestore(app);

    let TEACHER_ID = '';
    const urlParams = new URLSearchParams(window.location.search);
    const courseId = urlParams.get('id');

    const header = document.getElementById('courseHeader');
    const statStudentsEl = document.getElementById('statStudents');
    const statLessonsEl = document.getElementById('statLessons');
    const statRevenueEl = document.getElementById('statRevenue');
    const statCompletionEl = document.getElementById('statCompletion');
    const studentsList = document.getElementById('studentsList');
    const pageTitle = document.getElementById('pageTitle');
    const viewLessonsBtn = document.getElementById('viewLessonsBtn');
    const uploadLessonBtn = document.getElementById('uploadLessonBtn');

    // ---------- حماية ----------
    onAuthStateChanged(auth, async (user) => {
      if (!user) { window.location.href = 'login.html'; return; }
      TEACHER_ID = user.uid;
      document.body.classList.add('auth-ready');
      if (courseId) loadCourseDetails(courseId);
      else header.innerHTML = '<div class="empty-state"><i class="fas fa-exclamation-triangle"></i><br>لم يتم تحديد كورس</div>';
    });

    // ---------- Sidebar Mobile ----------
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');
    document.getElementById('hamburgerBtn').addEventListener('click', () => { sidebar.classList.add('open'); overlay.classList.add('show'); });
    overlay.addEventListener('click', () => { sidebar.classList.remove('open'); overlay.classList.remove('show'); });
    document.querySelectorAll('.sidebar nav a').forEach(link => {
      link.addEventListener('click', () => { if (window.innerWidth <= 768) { sidebar.classList.remove('open'); overlay.classList.remove('show'); } });
    });
    document.getElementById('logoutBtn').addEventListener('click', () => {
      if (confirm('هل تريد تسجيل الخروج؟')) signOut(auth).then(() => window.location.href = 'login.html');
    });

    // ---------- Toast ----------
    function showToast(msg, type = 'success') {
      const container = document.getElementById('toastContainer');
      const toast = document.createElement('div'); toast.className = `toast ${type}`;
      toast.innerHTML = `<i class="fas ${type==='success'?'fa-check-circle':'fa-exclamation-circle'}"></i> ${msg}`;
      container.appendChild(toast); setTimeout(() => toast.remove(), 3000);
    }

    async function loadCourseDetails(id) {
      try {
        const base = `teachers/${TEACHER_ID}`;

        // 1. جلب بيانات الكورس
        const docRef = doc(db, base, 'courses', id);
        const docSnap = await getDoc(docRef);
        if (!docSnap.exists()) { header.innerHTML = '<div class="empty-state"><i class="fas fa-exclamation-triangle"></i><br>الكورس غير موجود</div>'; return; }
        const course = { id: docSnap.id, ...docSnap.data() };
        pageTitle.textContent = `📘 ${course.title || 'تفاصيل الكورس'}`;
        viewLessonsBtn.href = `lessons.html?courseId=${id}`;
        uploadLessonBtn.href = `lesson-upload.html?courseId=${id}`;
        renderHeader(course);

        // 2. جلب enrollments من جميع الطلاب (للإحصائيات)
        const studentsSnap = await getDocs(collection(db, 'students'));
        const studentIds = [];
        let totalRevenue = 0, totalProgress = 0, enrollmentCount = 0;

        for (const studentDoc of studentsSnap.docs) {
          const sid = studentDoc.id;
          const enrollSnap = await getDocs(query(collection(db, 'students', sid, 'enrollments'), where('courseId', '==', id)));
          enrollSnap.forEach(enrollDoc => {
            const enroll = enrollDoc.data();
            studentIds.push(sid);
            if (enroll.price) totalRevenue += Number(enroll.price);
            totalProgress += (enroll.progress || 0);
            enrollmentCount++;
          });
        }

        // 3. جلب عدد الدروس
        const lessonsSnap = await getDocs(query(collection(db, base, 'lessons'), where('courseId', '==', id)));
        const lessonCount = lessonsSnap.size;

        // 4. تحديث الإحصائيات
        statStudentsEl.textContent = studentIds.length;
        statLessonsEl.textContent = lessonCount;
        statRevenueEl.textContent = '$' + totalRevenue.toFixed(0);
        statCompletionEl.textContent = enrollmentCount > 0 ? Math.round(totalProgress / enrollmentCount) + '%' : '0%';

        // 5. عرض الطلاب المسجلين
        if (studentIds.length === 0) {
          studentsList.innerHTML = '<div class="empty-state"><i class="fas fa-user-graduate"></i><br>لا يوجد طلاب مسجلين بعد</div>';
        } else {
          let html = '';
          for (const sid of [...new Set(studentIds)]) {
            const userRef = doc(db, 'students', sid, 'profile', 'info');
            const userSnap = await getDoc(userRef);
            if (userSnap.exists()) {
              const user = userSnap.data();
              const name = user.name || user.displayName || 'طالب';
              const email = user.email || '';
              const initial = name.charAt(0).toUpperCase();
              html += `<div class="student-item"><div class="avatar">${initial}</div><div class="name">${name}</div><div class="email">${email}</div></div>`;
            }
          }
          studentsList.innerHTML = html || '<div class="empty-state">لا توجد تفاصيل للطلاب</div>';
        }

      } catch (error) { console.error(error); showToast('فشل تحميل التفاصيل', 'error'); }
    }

    function renderHeader(course) {
      const statusClass = course.status === 'archived' ? 'archived' : '';
      const statusLabel = course.status === 'archived' ? 'مؤرشفة' : 'نشطة';
      header.innerHTML = `
        ${course.thumbnail ? `<img class="thumb" src="${course.thumbnail}" alt="${course.title}">` : `<div class="thumb" style="display:flex;align-items:center;justify-content:center;background:#eef2f8;color:#8a9bb5;"><i class="fas fa-image" style="font-size:2.5rem;"></i></div>`}
        <div class="info">
          <h2>${escapeHtml(course.title || 'كورس بدون عنوان')}</h2>
          <div class="desc">${escapeHtml(course.description || 'لا يوجد وصف')}</div>
          <div class="meta">
            <span><i class="fas fa-tag"></i> $${course.price || '0'}</span>
            <span><i class="fas fa-book"></i> ${course.subject || '—'}</span>
            <span><i class="fas fa-graduation-cap"></i> ${course.grade || '—'}</span>
            <span><i class="fas fa-calendar-alt"></i> ${course.createdAt ? new Date(course.createdAt.seconds*1000).toLocaleDateString('ar-EG') : '—'}</span>
            <span class="badge-status ${statusClass}">${statusLabel}</span>
          </div>
        </div>
      `;
    }

    function escapeHtml(text) { if (!text) return ''; return String(text).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[m])); }

    // ---------- لغة ووضع ليلي ----------
    let lang = 'ar';
    const langToggle = document.getElementById('langToggle'), darkToggle = document.getElementById('darkToggle'), langLabel = document.getElementById('langLabel');
    const mainEl = document.getElementById('mainContent');
    const translations = {
      ar: { dashboard:'لوحة التحكم', courses:'الكورسات', lessons:'الدروس', live:'البث المباشر', students:'الطلاب', assignments:'الواجبات', exams:'الامتحانات', revenue:'الإيرادات', messages:'الرسائل', settings:'الإعدادات', logout:'تسجيل الخروج' },
      en: { dashboard:'Dashboard', courses:'Courses', lessons:'Lessons', live:'Live Classes', students:'Students', assignments:'Assignments', exams:'Exams', revenue:'Revenue', messages:'Messages', settings:'Settings', logout:'Logout' }
    };
    function applyLanguage(lc) {
      const t = translations[lc];
      document.querySelectorAll('[data-key]').forEach(el => { if(t[el.dataset.key]) el.textContent = t[el.dataset.key]; });
      document.querySelector('.navbar h1').textContent = lc==='ar' ? '📘 تفاصيل الكورس' : '📘 Course Details';
      viewLessonsBtn.innerHTML = lc==='ar' ? '<i class="fas fa-file-alt"></i> عرض الدروس' : '<i class="fas fa-file-alt"></i> View Lessons';
      uploadLessonBtn.innerHTML = lc==='ar' ? '<i class="fas fa-upload"></i> رفع درس' : '<i class="fas fa-upload"></i> Upload Lesson';
      document.querySelector('.action-bar a.btn-secondary').innerHTML = lc==='ar' ? '<i class="fas fa-arrow-left"></i> العودة للكورسات' : '<i class="fas fa-arrow-left"></i> Back to Courses';
      document.querySelector('.stats-grid .stat-card:nth-child(1) .label').textContent = lc==='ar' ? 'الطلاب' : 'Students';
      document.querySelector('.stats-grid .stat-card:nth-child(2) .label').textContent = lc==='ar' ? 'الدروس' : 'Lessons';
      document.querySelector('.stats-grid .stat-card:nth-child(3) .label').textContent = lc==='ar' ? 'الإيرادات' : 'Revenue';
      document.querySelector('.stats-grid .stat-card:nth-child(4) .label').textContent = lc==='ar' ? 'الإكمال' : 'Completion';
      if (lc === 'ar') { mainEl.style.marginRight = '260px'; mainEl.style.marginLeft = '0'; document.documentElement.dir = 'rtl'; }
      else { mainEl.style.marginRight = '0'; mainEl.style.marginLeft = '260px'; document.documentElement.dir = 'ltr'; }
    }
    langToggle.addEventListener('click', () => { lang = lang==='ar'?'en':'ar'; langLabel.textContent = lang.toUpperCase(); applyLanguage(lang); });
    darkToggle.addEventListener('click', () => {
      document.body.classList.toggle('dark-mode');
      darkToggle.innerHTML = document.body.classList.contains('dark-mode') ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
    });
    applyLanguage('ar');
    console.log('✅ Zentor Course Details ready.');
  </script>
</body>
</html>
